<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/initializationFragment">

    <fragment
        android:id="@+id/initializationFragment"
        android:name="edu.iesam.superheroes.features.presentation.initialization.InitializationFragment"
        android:label="InitializationFragment"
        tools:layout="@layout/initialization_fragment">
        <action
            android:id="@+id/action_initializationFragment_to_listFragment"
            app:destination="@id/listFragment" />
    </fragment>

    <fragment
        android:id="@+id/listFragment"
        android:name="edu.iesam.superheroes.features.presentation.list.ListFragment"
        android:label="ListFragment"
        tools:layout="@layout/list_fragment">
        <action
            android:id="@+id/action_listFragment_to_detailFragment"
            app:destination="@id/detailFragment" />
    </fragment>

    <fragment
        android:id="@+id/detailFragment"
        android:name="edu.iesam.superheroes.features.presentation.detail.DetailFragment"
        android:label="DetailFragment"
        tools:layout="@layout/detail_fragment">
        <argument
            android:name="superHeroId"
            app:argType="integer" />
    </fragment>

</navigation>